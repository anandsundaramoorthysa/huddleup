{
  "name": "vscode-huddleup",
  "displayName": "HuddleUp",
  "description": "Huddle up your team's AI coding sessions — snapshot and resume work across AI tools",
  "version": "0.1.1",
  "publisher": "AnandSundaramoorthySa",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/anandsundaramoorthysa/huddleup.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "media/marketplace-icon.png",
  "galleryBanner": {
    "color": "#EEF2FF",
    "theme": "light"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "huddleup.snapshot",
        "title": "HuddleUp: Snapshot current session"
      },
      {
        "command": "huddleup.resume",
        "title": "HuddleUp: Resume a thread"
      },
      {
        "command": "huddleup.standup",
        "title": "HuddleUp: Show team standup"
      },
      {
        "command": "huddleup.threadNew",
        "title": "HuddleUp: Create new thread"
      },
      {
        "command": "huddleup.threadList",
        "title": "HuddleUp: List threads"
      },
      {
        "command": "huddleup.refresh",
        "title": "HuddleUp: Refresh sidebar"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "huddleup-sidebar",
          "title": "HuddleUp",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "huddleup-sidebar": [
        {
          "type": "webview",
          "id": "huddleup.panel",
          "name": "HuddleUp"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.26.0"
  }
}
