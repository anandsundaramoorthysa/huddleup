---
import { Icon } from 'astro-icon/components';
import { FAQS } from '../config';
---

<section id="faq" class="section">
  <div class="container-wide">
    <span class="section-label">FAQ</span>
    <h2 class="section-title">Questions teams ask before installing</h2>
    <p class="section-desc">
      If your answer isn't here, open an issue on GitHub — we'll add it.
    </p>

    <ul class="mt-12 grid gap-3 max-w-3xl">
      {FAQS.map((item, idx) => (
        <li class="card !p-0 reveal">
          <details class="group">
            <summary
              class="flex items-center justify-between gap-4 cursor-pointer list-none px-5 py-4 select-none"
              style="color: var(--ink);"
            >
              <span class="text-[15px] font-semibold pr-2">{item.q}</span>
              <span
                class="shrink-0 inline-flex items-center justify-center w-7 h-7 rounded-md transition-transform group-open:rotate-180"
                style="background: var(--surface-alt); color: var(--muted);"
                aria-hidden="true"
              >
                <Icon name="lucide:chevron-down" width="16" height="16" />
              </span>
            </summary>
            <div class="px-5 pb-5 -mt-1 text-sm leading-relaxed" style="color: var(--muted);">{item.a}</div>
          </details>
        </li>
      ))}
    </ul>
  </div>
</section>
