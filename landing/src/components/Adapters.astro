---
const adapters = [
  {
    name: 'Cursor',
    desc: 'Reads ~/.cursor/{sessions,chats}/ and the workspaceStorage folders under VS Code-style globalStorage on macOS, Linux, and Windows.',
  },
  {
    name: 'Claude Code',
    desc: 'Reads ~/.claude/projects/<hash>/*.jsonl (modern) and ~/.claude/sessions/*.jsonl (legacy). Writes CLAUDE.md with the Token Exhaustion Protocol.',
  },
  {
    name: 'Windsurf',
    desc: 'Detects ~/.windsurf/, ~/.codeium/, and the Windsurf/Codeium application data folders across platforms.',
  },
  {
    name: 'GitHub Copilot',
    desc: 'Reads VS Code globalStorage (github.copilot-chat) for Code, Code Insiders, and Cursor; also ~/.github/copilot/ and ~/.vscode/copilot/.',
  },
  {
    name: 'Codex CLI',
    desc: 'Detects ~/.codex/ and the Codex app data folders on macOS, Linux, and Windows. Parses JSON, JSONL, and plain-log session files.',
  },
  {
    name: 'Custom',
    desc: 'Add a new adapter in src/adapters/ — implement detect() + capture() and call registerAdapter(). About 80 lines. See docs/adapters.md.',
  },
];
---

<section class="section" id="adapters">
  <div class="container">
    <span class="section-label">Adapters</span>
    <h2 class="section-title">Works with the AI tools you already use</h2>
    <p class="section-desc">HuddleUp auto-detects every tool installed on the machine. Multiple adapters can match; their messages and open-file lists merge into a single snapshot.</p>

    <div class="adapters-grid">
      {adapters.map(a => (
        <div class="card adapter-card">
          <div class="adapter-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--indigo)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M8 12h8M12 8v8"/></svg>
          </div>
          <h3 class="adapter-name">{a.name}</h3>
          <p class="adapter-desc">{a.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .adapters-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:40px}
  .adapter-card{text-align:center}
  .adapter-icon{margin-bottom:12px;display:flex;justify-content:center}
  .adapter-name{font-size:1rem;font-weight:700;margin-bottom:6px}
  .adapter-desc{font-size:13px;color:var(--muted);line-height:1.6}
  @media(max-width:768px){
    .adapters-grid{grid-template-columns:repeat(2,1fr)}
  }
  @media(max-width:480px){
    .adapters-grid{grid-template-columns:1fr}
  }
</style>
