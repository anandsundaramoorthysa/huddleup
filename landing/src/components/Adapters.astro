---
const adapters = [
  { name: 'Cursor', icon: 'cursor', desc: 'Auto-detected from `.cursor/session.json` and history files.' },
  { name: 'Claude Code', icon: 'claude', desc: 'Reads `~/.claude/sessions/` and `CLAUDE.md` project config.' },
  { name: 'Windsurf', icon: 'windsurf', desc: 'Detects `.windsurf/sessions/` with full chat-log support.' },
  { name: 'GitHub Copilot', icon: 'copilot', desc: 'Pulls from VS Code\'s Copilot chat history and diagnostics.' },
  { name: 'Codex CLI', icon: 'codex', desc: 'Parses `.codex/sessions/` with conversation tree and file diffs.' },
  { name: 'Custom', icon: 'custom', desc: 'Extend via the adapter API — bring your own AI tool client.' },
];
---

<section class="section" id="adapters">
  <div class="container">
    <span class="section-label">Adapters</span>
    <h2 class="section-title">Works with the AI tools you already use</h2>
    <p class="section-desc">HuddleUp auto-detects which tool created a session. No manual mapping, no plugin hell.</p>

    <div class="adapters-grid">
      {adapters.map(a => (
        <div class="card adapter-card">
          <div class="adapter-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--indigo)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg>
          </div>
          <h3 class="adapter-name">{a.name}</h3>
          <p class="adapter-desc">{a.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .adapters-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:40px}
  .adapter-card{text-align:center}
  .adapter-icon{margin-bottom:12px;display:flex;justify-content:center}
  .adapter-name{font-size:1rem;font-weight:700;margin-bottom:6px}
  .adapter-desc{font-size:13px;color:var(--muted);line-height:1.6}
  @media(max-width:768px){
    .adapters-grid{grid-template-columns:repeat(2,1fr)}
  }
  @media(max-width:480px){
    .adapters-grid{grid-template-columns:1fr}
  }
</style>
