---
import { Icon } from 'astro-icon/components';
import { ADAPTERS } from '../config';
---

<section id="adapters" class="section" style="background: var(--surface-alt);">
  <div class="container-wide">
    <span class="section-label">Adapters</span>
    <h2 class="section-title">Auto-detected. Cross-platform. Easy to extend.</h2>
    <p class="section-desc">
      HuddleUp probes every supported tool on the machine. Multiple adapters can match — their open files and last messages merge into a single snapshot. The thread's <code class="code-inline">Tools</code> field lists every contributor.
    </p>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {ADAPTERS.map((a) => (
        <article
          class="card reveal relative overflow-hidden"
          style={`border-top: 3px solid ${a.accent};`}
        >
          <div
            class="inline-flex items-center justify-center w-11 h-11 rounded-xl mb-4"
            style={`background: color-mix(in srgb, ${a.accent} 14%, transparent); color: ${a.accent};`}
          >
            <Icon name={a.icon} width="22" height="22" aria-hidden="true" />
          </div>
          <h3 class="text-base font-semibold" style="color: var(--ink);">{a.name}</h3>
          <p class="mt-2 text-sm leading-relaxed" style="color: var(--muted);">{a.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
