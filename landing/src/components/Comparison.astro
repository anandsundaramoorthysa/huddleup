---
import { Icon } from 'astro-icon/components';
import { COMPARISON } from '../config';

function renderCell(v: boolean | string) {
  if (v === true) return { kind: 'yes' as const };
  if (v === false) return { kind: 'no' as const };
  if (v === 'partial') return { kind: 'partial' as const };
  return { kind: 'text' as const, label: String(v) };
}
---

<section id="compare" class="section">
  <div class="container-wide">
    <span class="section-label">Compare</span>
    <h2 class="section-title">How HuddleUp differs from static rules + memory banks</h2>
    <p class="section-desc">
      Static rules (CLAUDE.md, .cursor/rules) carry your conventions. Memory bank tools persist context for one tool. HuddleUp adds the missing live, cross-tool handoff layer.
    </p>

    <div
      class="mt-10 overflow-x-auto rounded-2xl border"
      style="border-color: var(--line); background: var(--surface-card);"
    >
      <table class="w-full text-sm">
        <thead style="background: var(--surface-alt);">
          <tr>
            {COMPARISON.headers.map((h, i) => {
              const isFirst = i === 0;
              const isLast = i === COMPARISON.headers.length - 1;
              const style = [
                `color: ${isLast ? 'var(--indigo)' : 'var(--ink)'};`,
                isFirst ? '' : 'text-align: center;',
              ].join(' ');
              return (
                <th class="px-4 py-3.5 font-semibold whitespace-nowrap" style={style}>{h}</th>
              );
            })}
          </tr>
        </thead>
        <tbody>
          {COMPARISON.rows.map((row) => (
            <tr style="border-top: 1px solid var(--line);">
              <td class="px-4 py-3.5 font-medium" style="color: var(--ink);">{row.feature}</td>
              {row.values.map((v, i) => {
                const cell = renderCell(v);
                const isHuddleupCol = i === row.values.length - 1;
                const tdStyle = isHuddleupCol
                  ? 'background: color-mix(in srgb, var(--indigo) 6%, transparent);'
                  : '';
                return (
                  <td class="px-4 py-3.5 text-center" style={tdStyle}>
                    {cell.kind === 'yes' && (
                      <span
                        class="inline-flex items-center justify-center w-6 h-6 rounded-full"
                        style="background: var(--cmp-yes-bg); color: var(--cmp-yes-fg);"
                        aria-label="Yes"
                      >
                        <Icon name="lucide:check" width="14" height="14" aria-hidden="true" />
                      </span>
                    )}
                    {cell.kind === 'no' && (
                      <span
                        class="inline-flex items-center justify-center w-6 h-6 rounded-full"
                        style="background: var(--cmp-no-bg); color: var(--cmp-no-fg);"
                        aria-label="No"
                      >
                        <Icon name="lucide:x" width="14" height="14" aria-hidden="true" />
                      </span>
                    )}
                    {cell.kind === 'partial' && (
                      <span
                        class="inline-flex items-center justify-center px-2.5 h-6 rounded-full text-[11px] font-semibold"
                        style="background: var(--cmp-partial-bg); color: var(--cmp-partial-fg);"
                        aria-label="Partial"
                      >
                        partial
                      </span>
                    )}
                    {cell.kind === 'text' && (
                      <span class="text-xs font-semibold" style="color: var(--ink);">{cell.label}</span>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
