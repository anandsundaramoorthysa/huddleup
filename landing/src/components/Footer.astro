---
import { Icon } from 'astro-icon/components';
import { SITE } from '../config';
const year = new Date().getFullYear();
---

<footer class="py-12" style="border-top: 1px solid var(--line); background: var(--surface);">
  <div class="container-wide">
    <div class="grid gap-10 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <a href="/" class="inline-flex" aria-label="HuddleUp home">
          <img src="/images/logo-horizontal.svg" alt="HuddleUp" width="140" height="32" class="logo-light" />
          <img src="/images/logo-horizontal-dark.svg" alt="HuddleUp" width="140" height="32" class="logo-dark" />
        </a>
        <p class="mt-4 text-sm max-w-xs" style="color: var(--muted);">{SITE.tagline}</p>
        <p class="mt-3 text-xs" style="color: var(--subtle);">© {year} {SITE.author} · AGPL-3.0</p>
      </div>

      <div>
        <p class="text-xs uppercase tracking-[0.16em] font-semibold mb-3" style="color: var(--subtle);">Product</p>
        <ul class="space-y-2 text-sm" style="color: var(--muted);">
          <li><a href="#features" class="hover:underline">Features</a></li>
          <li><a href="#adapters" class="hover:underline">Adapters</a></li>
          <li><a href="#compare" class="hover:underline">Compare</a></li>
          <li><a href="#faq" class="hover:underline">FAQ</a></li>
        </ul>
      </div>

      <div>
        <p class="text-xs uppercase tracking-[0.16em] font-semibold mb-3" style="color: var(--subtle);">Install</p>
        <ul class="space-y-2 text-sm" style="color: var(--muted);">
          <li><a href={SITE.npmUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 hover:underline"><Icon name="lucide:package" width="14" height="14" aria-hidden="true" />npm</a></li>
          <li><a href={SITE.vsCodeUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 hover:underline"><Icon name="lucide:panel-left" width="14" height="14" aria-hidden="true" />VS Code Marketplace</a></li>
          <li><a href={SITE.openVsxUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 hover:underline"><Icon name="lucide:puzzle" width="14" height="14" aria-hidden="true" />Open VSX</a></li>
        </ul>
      </div>

      <div>
        <p class="text-xs uppercase tracking-[0.16em] font-semibold mb-3" style="color: var(--subtle);">Project</p>
        <ul class="space-y-2 text-sm" style="color: var(--muted);">
          <li><a href={SITE.repo} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 hover:underline"><Icon name="lucide:github" width="14" height="14" aria-hidden="true" />GitHub</a></li>
          <li><a href={`${SITE.repo}/issues`} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 hover:underline"><Icon name="lucide:bug" width="14" height="14" aria-hidden="true" />Issues</a></li>
          <li><a href={`${SITE.repo}/blob/master/CHANGELOG.md`} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 hover:underline"><Icon name="lucide:scroll-text" width="14" height="14" aria-hidden="true" />Changelog</a></li>
          <li><a href={`${SITE.repo}/blob/master/LICENSE`} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 hover:underline"><Icon name="lucide:scale" width="14" height="14" aria-hidden="true" />AGPL-3.0</a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>
