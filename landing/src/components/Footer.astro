---
import { SITE } from '../config';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo-link">
        <img src="/images/logo-horizontal.svg" alt="HuddleUp" width="120" height="28" />
      </a>
      <p class="footer-tagline">{SITE.tagline}</p>
    </div>
    <nav class="footer-nav">
      <a href="#features">Features</a>
      <a href="#how-it-works">How it works</a>
      <a href="#quick-start">Quick start</a>
      <a href="#adapters">Adapters</a>
      <a href={SITE.repo} target="_blank" rel="noopener">GitHub</a>
    </nav>
    <div class="footer-meta">
      <a href={`${SITE.repo}/blob/master/LICENSE`} target="_blank" rel="noopener">AGPL-3.0</a>
      <span class="footer-sep">·</span>
      <span>&copy; {year} {SITE.author}</span>
    </div>
  </div>
</footer>

<style>
  .footer{
    border-top:1px solid var(--border);
    padding:40px 0;
    font-size:14px;
    color:var(--subtle);
  }
  .footer-inner{display:flex;align-items:center;gap:24px;flex-wrap:wrap}
  .footer-brand{flex:1;min-width:200px}
  .footer-logo-link{display:inline-block;line-height:0;margin-bottom:4px}
  .footer-tagline{margin:0;font-size:13px}
  .footer-nav{display:flex;gap:16px;flex-wrap:wrap}
  .footer-nav a{color:var(--muted)}
  .footer-nav a:hover{color:var(--indigo)}
  .footer-meta{font-size:13px}
  .footer-sep{margin:0 6px}
  @media(max-width:600px){
    .footer-inner{flex-direction:column;align-items:flex-start;gap:16px}
  }
</style>
