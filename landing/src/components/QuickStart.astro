---
import { Icon } from 'astro-icon/components';
import { SITE, QUICKSTART_STEPS } from '../config';
---

<section id="quick-start" class="section" style="background: var(--surface-alt);">
  <div class="container-wide">
    <span class="section-label">Quick start</span>
    <h2 class="section-title">Four commands. Under sixty seconds.</h2>
    <p class="section-desc">
      No sign-up, no account, no backend. Just Node.js, git, and a terminal.
    </p>

    <ol class="mt-12 grid gap-5 max-w-3xl">
      {QUICKSTART_STEPS.map((step, idx) => (
        <li class="card reveal grid sm:grid-cols-[44px_1fr] gap-5 items-start">
          <div
            class="inline-flex items-center justify-center w-11 h-11 rounded-full font-bold text-base"
            style="background: var(--indigo); color: white;"
          >
            {idx + 1}
          </div>
          <div class="min-w-0">
            <h3 class="text-base font-semibold mb-3" style="color: var(--ink);">{step.label}</h3>
            <div class="relative group">
              <pre
                class="rounded-lg p-4 pr-12 font-mono text-[13px] overflow-x-auto"
                style="background: var(--surface-code); color: var(--surface-code-text);"
              ><code>{step.code.split('\n').map((line) => `$ ${line}`).join('\n')}</code></pre>
              <button
                type="button"
                data-copy={step.code}
                class="absolute top-2.5 right-2.5 inline-flex items-center justify-center w-8 h-8 rounded-md transition-colors"
                style="background: rgba(255,255,255,0.06); color: #94A3B8;"
                aria-label={`Copy: ${step.label}`}
              >
                <Icon name="lucide:copy" width="14" height="14" aria-hidden="true" />
              </button>
            </div>
            <p class="mt-3 text-sm" style="color: var(--muted);">{step.caption}</p>
          </div>
        </li>
      ))}
    </ol>

    <p class="mt-10 text-sm text-center" style="color: var(--subtle);">
      Distributed via <a href={SITE.npmUrl} target="_blank" rel="noopener" class="underline" style="color: var(--indigo);">npm</a>
      · VS Code extension via <a href={SITE.vsCodeUrl} target="_blank" rel="noopener" class="underline" style="color: var(--indigo);">Marketplace</a>
      and <a href={SITE.openVsxUrl} target="_blank" rel="noopener" class="underline" style="color: var(--indigo);">Open VSX</a>
      · Open source on <a href={SITE.repo} target="_blank" rel="noopener" class="underline" style="color: var(--indigo);">GitHub</a>
      under AGPL-3.0
    </p>
  </div>
</section>
