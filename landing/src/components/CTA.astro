---
import { Icon } from 'astro-icon/components';
import { SITE } from '../config';
---

<section class="section" style="background: linear-gradient(180deg, var(--surface) 0%, var(--surface-alt) 100%);">
  <div class="container-narrow text-center">
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight" style="color: var(--ink); line-height: 1.15;">
      Stop re-explaining.
      <br />
      Start shipping.
    </h2>
    <p class="mt-5 text-base sm:text-lg" style="color: var(--muted);">
      One install command. One snapshot. One resume. Your team is huddled in.
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <button
        type="button"
        data-copy={SITE.installCommand}
        class="btn btn-primary"
        aria-label="Copy install command"
      >
        <Icon name="lucide:package" width="16" height="16" aria-hidden="true" />
        <span class="font-mono text-[13px]">$ {SITE.installCommand}</span>
        <span class="ml-1 inline-flex items-center gap-1 text-[11px] uppercase tracking-wider" data-copy-label>
          <Icon name="lucide:copy" width="12" height="12" aria-hidden="true" />
          Copy
        </span>
      </button>
      <a href={SITE.repo} class="btn btn-outline" target="_blank" rel="noopener">
        <Icon name="lucide:github" width="16" height="16" aria-hidden="true" />
        GitHub
      </a>
      <a href={SITE.vsCodeUrl} class="btn btn-outline" target="_blank" rel="noopener">
        <Icon name="lucide:panel-left" width="16" height="16" aria-hidden="true" />
        VS Code extension
      </a>
    </div>
  </div>
</section>
