---
import { Icon } from 'astro-icon/components';
import { NAV, SITE } from '../config';
---

<header class="sticky top-0 z-50 backdrop-blur" style="background: color-mix(in srgb, var(--surface) 80%, transparent); border-bottom: 1px solid var(--line);">
  <div class="container-wide flex items-center gap-6 h-16">
    <a href="/" class="flex items-center" aria-label="HuddleUp home">
      <img src="/images/logo-horizontal.svg" alt="HuddleUp" width="148" height="34" class="logo-light" />
      <img src="/images/logo-horizontal-dark.svg" alt="HuddleUp" width="148" height="34" class="logo-dark" />
    </a>

    <nav class="hidden md:flex items-center gap-1 flex-1">
      {NAV.map((item) => (
        <a
          href={item.href}
          class="px-3 py-2 rounded-md text-sm font-medium transition-colors hover:no-underline"
          style="color: var(--muted);"
          onmouseover="this.style.color='var(--ink)'; this.style.background='var(--surface-alt)'"
          onmouseout="this.style.color='var(--muted)'; this.style.background='transparent'"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <a
        href={SITE.repo}
        target="_blank"
        rel="noopener"
        class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-semibold transition-colors"
        style="border: 1px solid var(--line); color: var(--ink);"
        aria-label="Star HuddleUp on GitHub"
      >
        <Icon name="lucide:star" width="14" height="14" aria-hidden="true" />
        <span>Star on GitHub</span>
      </a>

      <button
        type="button"
        data-theme-toggle
        class="inline-flex items-center justify-center w-9 h-9 rounded-md transition-colors"
        style="border: 1px solid var(--line); color: var(--ink);"
        aria-label="Toggle dark mode"
      >
        <Icon name="lucide:sun" width="16" height="16" class="block dark:hidden" aria-hidden="true" />
        <Icon name="lucide:moon" width="16" height="16" class="hidden dark:block" aria-hidden="true" />
      </button>

      <button
        type="button"
        id="menuToggle"
        class="md:hidden inline-flex items-center justify-center w-9 h-9 rounded-md transition-colors"
        style="border: 1px solid var(--line); color: var(--ink);"
        aria-label="Open menu"
        aria-controls="mobileNav"
        aria-expanded="false"
      >
        <Icon name="lucide:menu" width="18" height="18" aria-hidden="true" />
      </button>
    </div>
  </div>

  <nav
    id="mobileNav"
    hidden
    class="md:hidden border-t flex flex-col px-5 py-3 gap-1"
    style="border-color: var(--line); background: var(--surface);"
  >
    {NAV.map((item) => (
      <a href={item.href} class="px-3 py-2 rounded-md text-sm font-medium" style="color: var(--ink);">
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById('menuToggle');
    const nav = document.getElementById('mobileNav');
    if (!btn || !nav) return;
    btn.addEventListener('click', () => {
      const open = !nav.hasAttribute('hidden');
      if (open) {
        nav.setAttribute('hidden', '');
        btn.setAttribute('aria-expanded', 'false');
      } else {
        nav.removeAttribute('hidden');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
    nav.addEventListener('click', (e) => {
      if (e.target && e.target.tagName === 'A') {
        nav.setAttribute('hidden', '');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>
