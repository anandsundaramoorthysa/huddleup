---
import { SITE } from '../config';

const features = [
  {
    title: 'Snapshot in seconds',
    desc: 'Capture open files, git diff, terminal history, and AI chat context into a single portable snapshot file. No config needed.',
    img: '/images/screenshot-snapshot.png',
    imgAlt: 'Terminal showing huddleup snapshot command',
  },
  {
    title: 'Resume instantly',
    desc: 'Teammates run one `huddleup resume` command and get the exact same context — files, chat history, even terminal scrollback.',
    img: '/images/screenshot-resume.png',
    imgAlt: 'Terminal showing huddleup resume command',
  },
  {
    title: 'VS Code companion',
    desc: 'The extension adds a sidebar panel, status bar widget, and context-menu commands so you never leave your editor.',
    img: '/images/screenshot-sidebar.png',
    imgAlt: 'VS Code sidebar showing HuddleUp extension panel',
  },
  {
    title: 'Multi-tool support',
    desc: 'Works with Cursor, Claude Code, Windsurf, Copilot, and Codex CLI. The adapter system auto-detects which AI tool created the session.',
  },
  {
    title: 'Portable & private',
    desc: 'Snapshots are local JSONL files — no cloud, no accounts, no data leaves your machine. Share via git, Slack, or any file transfer.',
  },
  {
    title: 'No lock-in',
    desc: 'Open source (AGPL-3.0), CLI-first philosophy, zero dependencies beyond Node.js 18+. Uninstall any time with no residue.',
  },
];
---

<section class="section" id="features">
  <div class="container">
    <span class="section-label">Features</span>
    <h2 class="section-title">Everything your team needs for seamless AI handoffs</h2>
    <p class="section-desc">{SITE.description}</p>

    <div class="features-grid">
      {features.map((f, i) => (
        <article class="card feature-card">
          {f.img && (
            <div class="feature-screenshot screenshot-frame">
              <img src={f.img} alt={f.imgAlt} loading="lazy" />
            </div>
          )}
          <div class="feature-body">
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:40px}
  .feature-card{display:flex;flex-direction:column;gap:20px}
  .feature-card:first-child{grid-column:1/-1}
  .feature-card:first-child .feature-screenshot{max-width:700px}
  .feature-screenshot{overflow:hidden}
  .feature-screenshot img{width:100%;display:block;transition:transform .3s}
  .feature-card:hover .feature-screenshot img{transform:scale(1.02)}
  .feature-title{font-size:1.1rem;font-weight:700;margin-bottom:8px}
  .feature-desc{font-size:14px;color:var(--muted);line-height:1.7}
  @media(max-width:768px){
    .features-grid{grid-template-columns:1fr}
  }
</style>
