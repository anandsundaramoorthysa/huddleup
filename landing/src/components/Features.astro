---
import { Icon } from 'astro-icon/components';
import { FEATURES } from '../config';
---

<section id="features" class="section">
  <div class="container-wide">
    <span class="section-label">Features</span>
    <h2 class="section-title">Everything teams need for seamless AI handoffs</h2>
    <p class="section-desc">
      Built for the actual loop: code with an AI tool, snapshot, hand off, resume. No backend to host. No accounts to provision.
    </p>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {FEATURES.map((f) => (
        <article class="card reveal flex flex-col">
          <div
            class="inline-flex items-center justify-center w-10 h-10 rounded-lg mb-4"
            style="background: var(--indigo-soft); color: var(--indigo);"
          >
            <Icon name={f.icon} width="20" height="20" aria-hidden="true" />
          </div>
          <h3 class="text-base font-semibold" style="color: var(--ink);">{f.title}</h3>
          <p class="mt-2 text-sm leading-relaxed flex-1" style="color: var(--muted);">{f.desc}</p>
          {f.screenshot && (
            <div class="mt-5 -mx-1 rounded-lg overflow-hidden border" style="border-color: var(--line); background: var(--surface-alt);">
              <img src={f.screenshot} alt={f.alt} loading="lazy" decoding="async" class="w-full h-auto" />
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
