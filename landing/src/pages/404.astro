---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from '../config';
---

<BaseLayout title="Page not found">
  <Header />
  <main class="container-narrow text-center" style="padding: 96px 20px 128px;">
    <div
      class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mx-auto"
      style="background: var(--indigo-soft); color: var(--indigo);"
    >
      <Icon name="lucide:compass" width="28" height="28" aria-hidden="true" />
    </div>

    <h1 class="mt-8 text-6xl sm:text-7xl font-extrabold tracking-tight" style="color: var(--ink);">
      404
    </h1>
    <p class="mt-3 text-base sm:text-lg" style="color: var(--muted);">
      We couldn't find that page. It might have been moved, archived, or never existed.
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="/" class="btn btn-primary">
        <Icon name="lucide:home" width="16" height="16" aria-hidden="true" />
        Back to home
      </a>
      <a href={SITE.repo} target="_blank" rel="noopener" class="btn btn-outline">
        <Icon name="lucide:github" width="16" height="16" aria-hidden="true" />
        GitHub
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
