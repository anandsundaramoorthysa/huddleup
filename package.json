{
  "name": "huddleup",
  "version": "0.1.2",
  "description": "Huddle up your team's AI coding sessions. Snapshot and resume work across Claude Code, Cursor, Codex, Copilot, and Windsurf.",
  "type": "module",
  "bin": {
    "huddleup": "./bin/huddleup.js",
    "hup": "./bin/huddleup.js"
  },
  "files": [
    "bin/",
    "dist/",
    "src/templates/"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-templates.mjs",
    "build:assets": "node scripts/build-raster-assets.mjs",
    "dev": "tsc --watch",
    "start": "node bin/huddleup.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.3.0",
    "simple-git": "^3.24.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "sharp": "^0.35.2",
    "to-ico": "^1.1.5",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/anandsundaramoorthysa/huddleup.git"
  },
  "homepage": "https://github.com/anandsundaramoorthysa/huddleup",
  "keywords": [
    "ai",
    "coding",
    "handoff",
    "claude-code",
    "cursor",
    "codex",
    "copilot",
    "windsurf",
    "team",
    "collaboration"
  ]
}
